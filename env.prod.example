# =================================================================
# SunFlowCRM — Production Environment (Stack Auth)
# =================================================================
# 1. Copy to .env.prod:  cp .env.prod.example .env.prod
# 2. Fill in ALL values marked with <...>
# 3. IMPORTANT: First boot requires a two-phase setup for Stack Auth
#    (see docs/AUTH/STACK_AUTH_PROD_SETUP.md)
# =================================================================


# =================================================================
# Application
# =================================================================
NEXT_PUBLIC_APP_NAME="SunFlowCRM"
NEXT_PUBLIC_APP_URL="https://crm.yourdomain.com"

# Port exposed on the host (default: 3000)
APP_PORT=3000


# =================================================================
# Main Database (PostgreSQL — App data)
# =================================================================
POSTGRES_DB=sun_uw
POSTGRES_USER=postgres
# Generate: openssl rand -hex 24
POSTGRES_PASSWORD=<strong-postgres-password>


# =================================================================
# Redis
# =================================================================
# Generate: openssl rand -hex 24
REDIS_PASSWORD=<strong-redis-password>


# =================================================================
# Stack Auth — Infrastructure
# =================================================================
# Dedicated PostgreSQL for Stack Auth (separate from app DB)
# Generate: openssl rand -hex 24
STACK_DB_PASSWORD=<strong-stack-db-password>

# ClickHouse password (used by Stack Auth analytics)
# Generate: openssl rand -hex 24
CLICKHOUSE_PASSWORD=<strong-clickhouse-password>

# Internal secret for Stack Auth server
# Generate: openssl rand -hex 32
STACK_SERVER_SECRET=<generate-with-openssl-rand-hex-32>

# Public URL where Stack Auth Dashboard is accessible
# If behind a reverse proxy: https://auth.yourdomain.com
# If exposed directly: http://<server-ip>:8101
NEXT_PUBLIC_STACK_URL=https://auth.yourdomain.com

# Stack Auth backend API URL (accessible from the browser)
NEXT_PUBLIC_STACK_API_URL=https://auth-api.yourdomain.com

# Port mappings (only relevant if not behind a reverse proxy)
STACK_DASHBOARD_PORT=8101
STACK_API_PORT=8102


# =================================================================
# Stack Auth — Email (SMTP for transactional emails)
# =================================================================
STACK_EMAIL_HOST=smtp.yourmailprovider.com
STACK_EMAIL_PORT=587
STACK_EMAIL_SECURE=true
STACK_EMAIL_USER=<smtp-username>
STACK_EMAIL_PASSWORD=<smtp-password>
STACK_EMAIL_SENDER=noreply@yourdomain.com


# =================================================================
# Stack Auth — Project Keys
# ⚠️ FILLED AFTER FIRST BOOT
# 1. Start stack-server first (phase 1):
#    docker compose -f docker-compose.prod.yml --env-file .env.prod up -d stack-postgres clickhouse stack-server
# 2. Open Stack Auth Dashboard at NEXT_PUBLIC_STACK_URL
# 3. Create a project → copy the three keys below
# 4. Fill in the keys, then start the full stack (phase 2):
#    docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
# =================================================================
NEXT_PUBLIC_STACK_PROJECT_ID=<proj_...>
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=<pck_...>
STACK_SECRET_SERVER_KEY=<ssk_...>


# =================================================================
# Internal Worker Secret
# =================================================================
# Generate: openssl rand -hex 32
INTERNAL_WORKER_SECRET=<generate-with-openssl-rand-hex-32>


# =================================================================
# Error Tracking (Sentry) — Optional
# =================================================================
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ORG=
NEXT_PUBLIC_SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DISABLED=false
